{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "files": {
    "ignore": [
      "dist/**",
      "node_modules/**",
      "scripts/**",
      "coverage/**",
      "tsconfig*.json"
    ]
  },
  "formatter": {
    "enabled": true,
    "lineWidth": 120,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf"
  },
  "javascript": {
    "formatter": {
      "semicolons": "always",
      "quoteStyle": "double",
      "trailingCommas": "all"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "warn",
        "noConsole": "off",
        "noImplicitAnyLet": "warn",
        "noAssignInExpressions": "error",
        "noMisleadingCharacterClass": "error",
        "noControlCharactersInRegex": "error",
        "noConfusingVoidType": "warn",
        "noGlobalIsNan": "error"
      },
      "correctness": {
        "noUnusedVariables": "warn",
        "noUnnecessaryContinue": "warn"
      },
      "style": {
        "useConst": "warn",
        "noVar": "error",
        "noNonNullAssertion": "warn",
        "noParameterAssign": "warn",
        "noUnusedTemplateLiteral": "warn",
        "useTemplate": "warn",
        "useNodejsImportProtocol": "error",
        "noUselessElse": "warn",
        "useExponentiationOperator": "warn",
        "useSingleVarDeclarator": "warn"
      },
      "complexity": {
        "noForEach": "warn",
        "useLiteralKeys": "warn",
        "useOptionalChain": "warn"
      },
      "performance": {
        "noDelete": "error"
      }
    }
  },
  "organizeImports": {
    "enabled": false
  }
}
